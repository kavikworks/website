# Kavik Works — Automation Pipeline Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit the .env file — it contains secrets.

# ── Google Cloud ──────────────────────────────────────────────
# Your GCP project ID (find it at console.cloud.google.com)
GCP_PROJECT=your-gcp-project-id

# Google Sheet ID (from the Sheet URL: /spreadsheets/d/{THIS_PART}/edit)
GOOGLE_SHEET_ID=

# Google Drive folder ID (from the folder URL: /drive/folders/{THIS_PART})
GOOGLE_DRIVE_FOLDER_ID=

# ── Email (Google Workspace SMTP) ─────────────────────────────
# App Password for contact@kavikworks.com
# Setup: myaccount.google.com → Security → 2-Step Verification → App passwords
# Create one named "Kavik Intake Pipeline", paste the 16-char password below.
GMAIL_APP_PASSWORD=
